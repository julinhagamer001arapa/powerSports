  "layout": {
    "viewport": {
      "maxWidth": "1920px",
      "minHeight": "100vh"
    },
    "structure": [
      "header",
      "hero",
      "mainDashboardGrid",
      "secondaryDashboardGrid",
      "bottomShortcuts"
    ],
    "grid": {
      "desktop": {
        "columns": 12,
        "gap": "18px",
        "areas": {
          "upcomingFights": "span 4",
          "officialRanking": "span 3",
          "highlights": "span 2",
          "leagueStats": "span 3",
          "featuredNews": "span 4",
          "featuredEvents": "span 3",
          "trendingAthletes": "span 5"
        }
      },
      "tablet": {
        "columns": 6,
        "gap": "16px",
        "areas": {
          "upcomingFights": "span 3",
          "officialRanking": "span 3",
          "highlights": "span 3",
          "leagueStats": "span 3",
          "featuredNews": "span 6",
          "featuredEvents": "span 3",
          "trendingAthletes": "span 3"
        }
      },
      "mobile": {
        "columns": 1,
        "gap": "14px",
        "areas": {
          "all": "span 1"
        }
      }
    },
    "breakpoints": {
      "mobile": "0px",
      "tablet": "768px",
      "desktop": "1200px",
      "wide": "1440px"
    }
  },
  "api": {
    "enabled": true,
    "baseUrl": "/api",
    "timeoutMs": 12000,
    "fallbackToStaticData": true,
    "endpoints": {
      "fighters": {
        "method": "GET",
        "path": "/fighting/fighters",
        "bindTo": "data.fighters"
      },
      "nextFight": {
        "method": "GET",
        "path": "/fighting/fights/next",
        "bindTo": "data.nextFight"
      },
      "upcomingFights": {
        "method": "GET",
        "path": "/fighting/fights/upcoming",
        "bindTo": "data.upcomingFights"
      },
      "officialRanking": {
        "method": "GET",
        "path": "/fighting/ranking/official",
        "bindTo": "data.officialRanking"
      },
      "highlights": {
        "method": "GET",
        "path": "/fighting/highlights",
        "bindTo": "data.highlights"
      },
      "leagueStats": {
        "method": "GET",
        "path": "/fighting/league/stats",
        "bindTo": "data.leagueStats"
      },
      "news": {
        "method": "GET",
        "path": "/fighting/news",
        "bindTo": "data.featuredNews"
      },
      "events": {
        "method": "GET",
        "path": "/fighting/events/featured",
        "bindTo": "data.featuredEvents"
      },
      "trendingAthletes": {
        "method": "GET",
        "path": "/fighting/athletes/trending",
        "bindTo": "data.trendingAthletes"
      },
      "shortcuts": {
        "method": "GET",
        "path": "/fighting/shortcuts",
        "bindTo": "data.bottomShortcuts"
      }
    },
    "expectedResponseShape": {
      "fighters": "Array<{ id, name, country, record, category, avatar }>",
      "nextFight": "{ id, date, time, category, arena, fighterAId, fighterBId, status }",
      "upcomingFights": "Array<{ id, date, time, fighterAId, fighterBId, category, status }>",
      "officialRanking": "Array<{ position, fighterId, country, record, category }>",
      "highlights": "Array<{ id, title, description, thumbnail, videoUrl }>",
      "leagueStats": "Array<{ id, label, value, unit, icon }>",
      "news": "Array<{ id, title, date, image, url }>",
      "events": "Array<{ id, name, date, time, arena, location, logo }>",
      "trendingAthletes": "Array<{ position, fighterId, category, record, avatar }>",
      "shortcuts": "Array<{ id, icon, title, description, href }>"
    }
  },

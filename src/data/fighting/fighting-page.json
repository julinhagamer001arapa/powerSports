  "animations": {
    "pageEntrance": {
      "type": "fade-up",
      "durationMs": 650,
      "easing": "ease-out"
    },
    "cardHover": {
      "transform": "translateY(-4px)",
      "boxShadow": "0 0 36px rgba(160, 32, 255, 0.58)",
      "transition": "all 220ms ease"
    },
    "buttonHover": {
      "transform": "translateY(-2px) scale(1.02)",
      "filter": "brightness(1.12)",
      "transition": "all 180ms ease"
    },
    "heroFightersFloat": {
      "enabled": true,
      "animationName": "subtleFightStance",
      "duration": "5s",
      "iterationCount": "infinite",
      "direction": "alternate",
      "transformRange": "translateY(-6px) translateX(3px)"
    },
    "cageSmokePulse": {
      "enabled": true,
      "target": "heroBackground lower smoke",
      "effect": "soft purple smoke pulse behind fighters",
      "duration": "3.8s",
      "iterationCount": "infinite"
    },

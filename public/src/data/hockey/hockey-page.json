          "leagueStats": "span 3",
          "featuredNews": "span 7",
          "leagueCalendar": "span 5"
        }
      },
      "tablet": {
        "columns": 6,
        "gap": "16px"
      },
      "mobile": {
        "columns": 1,
        "gap": "14px"
      }
    },
    "breakpoints": {
      "mobile": "0px",
      "tablet": "768px",
      "desktop": "1200px",
      "wide": "1440px"
    }
  },
  "api": {
    "enabled": true,
    "baseUrl": "/api",
    "timeoutMs": 12000,
    "fallbackToStaticData": true,
    "endpoints": {
      "teams": {
        "method": "GET",
        "path": "/teams",
        "bindTo": "data.teams"
      },
      "matches": {
        "method": "GET",
        "path": "/matches",
        "bindTo": "data.matches"
      },
      "standings": {
        "method": "GET",
        "path": "/standings",
        "bindTo": "data.standings"
      },
      "topScorers": {
        "method": "GET",
        "path": "/players/top-scorers",
        "bindTo": "data.topScorers"
      },
      "leagueStats": {
        "method": "GET",
        "path": "/league/stats",
        "bindTo": "data.leagueStats"
      },
      "news": {
        "method": "GET",
        "path": "/news",
        "bindTo": "data.featuredNews"
      },
      "videos": {
        "method": "GET",
        "path": "/videos/highlights",
        "bindTo": "data.momentHighlight"
      },
      "calendar": {
        "method": "GET",
        "path": "/calendar",
        "bindTo": "data.leagueCalendar"
      }
    },
    "expectedResponseShape": {
      "teams": "Array<{ id, name, shortName, logo, primaryColor, secondaryColor }>",
      "matches": "Array<{ id, date, time, homeTeamId, awayTeamId, arena, status }>",
      "standings": "Array<{ position, teamId, games, wins, losses, points }>",
      "topScorers": "Array<{ position, playerName, teamId, goals, avatar }>",
      "leagueStats": "Array<{ id, label, value, unit, icon }>",
      "news": "Array<{ id, category, title, date, image, url }>",
      "videos": "Array<{ id, title, subtitle, thumbnail, videoUrl }>",
      "calendar": "Array<{ id, date, time, homeTeamId, awayTeamId, arena }>"
    }
  },

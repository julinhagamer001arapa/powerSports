  "api": {
    "enabled": true,
    "baseUrl": "/api",
    "timeoutMs": 12000,
    "fallbackToStaticData": true,
    "endpoints": {
      "teams": {
        "method": "GET",
        "path": "/teams?league=american-football",
        "bindTo": "data.teams"
      },
      "nextGame": {
        "method": "GET",
        "path": "/american-football/games/next",
        "bindTo": "data.nextGame"
      },
      "gameCalendar": {
        "method": "GET",
        "path": "/american-football/games/calendar",
        "bindTo": "data.gameCalendar"
      },
      "standings": {
        "method": "GET",
        "path": "/american-football/standings",
        "bindTo": "data.standings"
      },
      "bestPlays": {
        "method": "GET",
        "path": "/american-football/highlights/best-plays",
        "bindTo": "data.bestPlays"
      },
      "playerHighlights": {
        "method": "GET",
        "path": "/american-football/players/highlights",
        "bindTo": "data.playerHighlights"
      },
      "news": {
        "method": "GET",
        "path": "/american-football/news",
        "bindTo": "data.featuredNews"
      },
      "leagueStats": {
        "method": "GET",
        "path": "/american-football/league/stats",
        "bindTo": "data.leagueStats"
      },
      "topScorers": {
        "method": "GET",
        "path": "/american-football/players/scorers",
        "bindTo": "data.topScorers"
      },
      "shortcuts": {
        "method": "GET",
        "path": "/american-football/shortcuts",
        "bindTo": "data.bottomShortcuts"
      }
    },
    "expectedResponseShape": {
      "teams": "Array<{ id, name, shortName, logo, primaryColor, secondaryColor }>",
      "nextGame": "{ id, date, time, stadium, homeTeamId, awayTeamId, status }",
      "gameCalendar": "Array<{ id, date, time, homeTeamId, awayTeamId, status }>",
      "standings": "Array<{ position, conference, teamId, games, wins, losses, percentage, points }>",
      "bestPlays": "{ id, title, description, thumbnail, videoUrl }",
      "playerHighlights": "Array<{ position, playerName, teamId, value, metric, avatar }>",
      "news": "Array<{ id, title, date, image, url }>",
      "leagueStats": "Array<{ id, label, value, unit, description, icon }>",
      "topScorers": "Array<{ position, playerName, teamId, value, unit, avatar }>",
      "shortcuts": "Array<{ id, icon, title, description, href }>"
    }
  },

  "layout": {
    "viewport": {
      "maxWidth": "1920px",
      "minHeight": "100vh"
    },
    "structure": [
      "header",
      "hero",
      "mainDashboardGrid",
      "secondaryDashboardGrid",
      "bottomShortcuts"
    ],
    "grid": {
      "desktop": {
        "columns": 12,
        "gap": "18px",
        "areas": {
          "upcomingGames": "span 3",
          "standings": "span 3",
          "leagueStats": "span 3",
          "topPlayers": "span 3",
          "bestMoments": "span 5",
          "featuredNews": "span 3",
          "leagueCalendar": "span 4"
        }
      },
      "tablet": {
        "columns": 6,
        "gap": "16px",
        "areas": {
          "upcomingGames": "span 3",
          "standings": "span 3",
          "leagueStats": "span 3",
          "topPlayers": "span 3",
          "bestMoments": "span 6",
          "featuredNews": "span 3",
          "leagueCalendar": "span 3"
        }
      },
      "mobile": {
        "columns": 1,
        "gap": "14px",
        "areas": {
          "all": "span 1"
        }
      }
    },
    "breakpoints": {
      "mobile": "0px",
      "tablet": "768px",
      "desktop": "1200px",
      "wide": "1440px"
    }
  },
  "api": {
    "enabled": true,
    "baseUrl": "/api",
    "timeoutMs": 12000,
    "fallbackToStaticData": true,
    "endpoints": {
      "teams": {
        "method": "GET",
        "path": "/teams?league=volleyball",
        "bindTo": "data.teams"
      },
      "upcomingGames": {
        "method": "GET",
        "path": "/volleyball/games/upcoming",
        "bindTo": "data.upcomingGames"
      },
      "standings": {
        "method": "GET",
        "path": "/volleyball/standings",
        "bindTo": "data.standings"
      },
      "leagueStats": {
        "method": "GET",
        "path": "/volleyball/league/stats",
        "bindTo": "data.leagueStats"
      },
      "topPlayers": {
        "method": "GET",
        "path": "/volleyball/players/top",
        "bindTo": "data.topPlayers"
      },
      "roundHighlight": {
        "method": "GET",
        "path": "/volleyball/highlights/round",
        "bindTo": "data.roundHighlight"
      },
      "bestMoments": {
        "method": "GET",
        "path": "/volleyball/highlights/best-moments",
        "bindTo": "data.bestMoments"
      },
      "news": {
        "method": "GET",
        "path": "/volleyball/news",
        "bindTo": "data.featuredNews"
      },
      "calendar": {
        "method": "GET",
        "path": "/volleyball/calendar",
        "bindTo": "data.leagueCalendar"
      },
      "shortcuts": {
        "method": "GET",
        "path": "/volleyball/shortcuts",
        "bindTo": "data.bottomShortcuts"
      }
    },
    "expectedResponseShape": {
      "teams": "Array<{ id, name, shortName, logo, primaryColor, secondaryColor }>",
      "upcomingGames": "Array<{ id, date, time, homeTeamId, awayTeamId, arena, status }>",
      "standings": "Array<{ position, teamId, games, wins, losses, points }>",
      "leagueStats": "Array<{ id, label, value, unit, description, icon }>",
      "topPlayers": "Array<{ position, playerName, teamId, points, avatar }>",
      "roundHighlight": "{ id, title, description, thumbnail, videoUrl, buttonLabel }",
      "bestMoments": "Array<{ id, title, description, thumbnail, videoUrl }>",
      "news": "Array<{ id, title, date, image, url }>",
      "calendar": "Array<{ id, date, time, homeTeamId, awayTeamId, arena }>",
      "shortcuts": "Array<{ id, icon, title, description, href }>"
    }
  },

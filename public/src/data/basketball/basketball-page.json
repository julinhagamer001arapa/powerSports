  "animations": {
    "pageEntrance": {
      "type": "fade-up",
      "durationMs": 650,
      "easing": "ease-out"
    },
    "cardHover": {
      "transform": "translateY(-4px)",
      "boxShadow": "0 0 34px rgba(255, 90, 0, 0.52)",
      "transition": "all 220ms ease"
    },
    "buttonHover": {
      "transform": "translateY(-2px) scale(1.02)",
      "filter": "brightness(1.12)",
      "transition": "all 180ms ease"
    },
    "heroPlayerFloat": {
      "enabled": true,
      "animationName": "subtleCourtFloat",
      "duration": "5s",
      "iterationCount": "infinite",
      "direction": "alternate",
      "transformRange": "translateY(-8px) translateX(4px)"
    },
    "backgroundParticles": {
      "enabled": true,
      "type": "orange-sparks",
      "color": "rgba(255, 90, 0, 0.56)",
      "density": "medium",
      "speed": "slow"
    }
  },
  "accessibility": {
    "contrastTarget": "WCAG AA",
    "useSemanticSections": true,
    "keyboardNavigation": true,
    "focusStyle": {
      "outline": "2px solid #FF5A00",
      "outlineOffset": "3px"
    },
    "imageAltRequired": true,

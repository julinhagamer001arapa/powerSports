  "api": {
    "enabled": true,
    "baseUrl": "/api",
    "timeoutMs": 12000,
    "fallbackToStaticData": true,
    "endpoints": {
      "teams": {
        "method": "GET",
        "path": "/teams?league=basketball",
        "bindTo": "data.teams"
      },
      "weeklyGames": {
        "method": "GET",
        "path": "/basketball/games/week",
        "bindTo": "data.weeklyGames"
      },
      "nextGame": {
        "method": "GET",
        "path": "/basketball/games/next",
        "bindTo": "data.nextGame"
      },
      "standings": {
        "method": "GET",
        "path": "/basketball/standings",
        "bindTo": "data.standings"
      },
      "weeklyHighlight": {
        "method": "GET",
        "path": "/basketball/highlights/week",
        "bindTo": "data.weeklyHighlight"
      },
      "topPlayers": {
        "method": "GET",
        "path": "/basketball/players/top",
        "bindTo": "data.topPlayers"
      },
      "news": {
        "method": "GET",
        "path": "/basketball/news",
        "bindTo": "data.featuredNews"
      },
      "leagueStats": {
        "method": "GET",
        "path": "/basketball/league/stats",
        "bindTo": "data.leagueStats"
      },
      "topScorers": {
        "method": "GET",
        "path": "/basketball/players/scorers",
        "bindTo": "data.topScorers"
      },
      "shortcuts": {
        "method": "GET",
        "path": "/basketball/shortcuts",
        "bindTo": "data.bottomShortcuts"
      }
    },
    "expectedResponseShape": {
      "teams": "Array<{ id, name, shortName, logo, primaryColor, secondaryColor }>",
      "weeklyGames": "Array<{ id, date, time, homeTeamId, awayTeamId, status }>",
      "nextGame": "{ id, date, time, league, homeTeamId, awayTeamId, homeLogo, awayLogo, status }",
      "standings": "Array<{ position, teamId, games, wins, losses, points }>",
      "weeklyHighlight": "{ id, category, title, description, thumbnail, videoUrl }",
      "topPlayers": "Array<{ position, playerName, teamId, mainValue, metric, avatar }>",
      "news": "Array<{ id, category, title, date, image, url }>",
      "leagueStats": "Array<{ id, label, value, unit, description, icon }>",
      "topScorers": "Array<{ position, playerName, teamId, value, unit, avatar }>",
      "shortcuts": "Array<{ id, icon, title, description, href }>"
    }
  },
